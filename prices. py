# ================= SAFE OPEN =================
def open_link(url):
    try:
        if os.system("command -v termux-open-url > /dev/null") == 0:
            os.system(f"termux-open-url '{url}'")
        else:
            webbrowser.open_new_tab(url)
    except:
        print("Can't open link")

